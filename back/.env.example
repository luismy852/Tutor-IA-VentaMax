# Requerida — clave de API de OpenAI
OPENAI_API_KEY=sk-...

# Opcional — ruta del archivo SQLite (default: conversations.db)
DATABASE_URL=conversations.db

# Opcional — modelo de OpenAI a usar (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Opcional — orígenes permitidos por CORS (default: localhost:3000)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
